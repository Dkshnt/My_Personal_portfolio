rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Media, static images, and general file attachments
    match /{allPaths=**} {
      // Allow any visitor to view uploaded assets
      allow read: if true;

      // Reject any uploads or mutations unless signed in as the matching admin ID
      allow write: if request.auth != null && request.auth.uid == "dikshant-admin-id-here";
    }
  }
}
