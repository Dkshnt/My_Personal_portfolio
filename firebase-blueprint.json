{
  "entities": {
    "Block": {
      "title": "Block",
      "description": "A dynamic content block representing text, image, or downloadable document.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "file_download"] },
        "value": { "type": "string" },
        "name": { "type": "string" },
        "sort_order": { "type": "number" }
      },
      "required": ["id", "type", "value", "sort_order"]
    }
  },
  "firestore": {
    "/blocks/{blockId}": {
      "schema": "Block",
      "description": "Collection of dynamic homepage content blocks."
    }
  }
}
